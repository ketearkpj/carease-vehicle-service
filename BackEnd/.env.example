# ========== SERVER CONFIGURATION ==========
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ========== DATABASE CONFIGURATION ==========
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carease
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# ========== JWT CONFIGURATION ==========
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# ========== EMAIL CONFIGURATION ==========
# Primary Email Service: SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@carease.com
SENDGRID_FROM_NAME=CAR EASE

# Fallback Email Service: Nodemailer (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=CAR EASE <noreply@carease.com>
EMAIL_REPLY_TO=support@carease.com

# ========== PAYMENT GATEWAY CONFIGURATION ==========
# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# M-PESA
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret

# Square
SQUARE_APPLICATION_ID=your_square_app_id
SQUARE_ACCESS_TOKEN=your_square_access_token

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=pk_test_your_flutterwave_key
FLUTTERWAVE_SECRET_KEY=sk_test_your_flutterwave_secret

# ========== EXTERNAL SERVICES ==========
# Cloudinary (Image Storage)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ========== LOGGING CONFIGURATION ==========
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# ========== SESSION CONFIGURATION ==========
SESSION_SECRET=your_session_secret_key

# ========== ADMIN SETTINGS ==========
ADMIN_EMAIL=admin@carease.com
ADMIN_PHONE=+1234567890

# ========== FEATURE FLAGS ==========
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_PAYMENT_VERIFICATION=true
